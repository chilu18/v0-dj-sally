# DJ Sally - Local Development Environment Variables
# Copy this file to .env.local and fill in your values

# Sally Remote Control API Configuration
# URL where your Sally remote-control API is running
SALLY_REMOTE_CONTROL_URL=http://127.0.0.1:8787

# Device ID for Sally commands
SALLY_DEVICE_ID=sally-samsung

# Admin token for authenticating with Sally API (required, keep secret!)
# DO NOT prefix with NEXT_PUBLIC_ - this must stay server-side only
SALLY_ADMIN_TOKEN=your-secret-token-here

# WebSocket Bridge Configuration
# Port for the local WebSocket bridge server
DJ_SALLY_WS_PORT=8080

# How long the bridge should wait for Sally command results
SALLY_WAIT_MS=10000

# WebSocket URL for the dashboard to connect to (client-side)
NEXT_PUBLIC_DJ_SALLY_WS_URL=ws://localhost:8080
